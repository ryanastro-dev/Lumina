{
  "openapi": "3.0.3",
  "info": {
    "title": "Lumina AI Processing Service",
    "version": "1.0.0"
  },
  "paths": {
    "/health": {
      "get": {
        "summary": "Health check",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/ingest": {
      "post": {
        "summary": "Ingest a text document into vector storage",
        "operationId": "ingest_document_ingest_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/IngestRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IngestResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid text or chunking input.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Request validation failed.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "Qdrant unavailable.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/check": {
      "post": {
        "summary": "Check text similarity against indexed documents",
        "operationId": "check_plagiarism_check_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CheckRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CheckResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid text or chunking input.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Request validation failed.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "Qdrant unavailable.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/extract-pdf": {
      "post": {
        "summary": "Extract plain text from an uploaded PDF",
        "operationId": "extract_pdf_extract_pdf_post",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_extract_pdf_extract_pdf_post"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PdfExtractResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid PDF input.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Request validation failed.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Body_extract_pdf_extract_pdf_post": {
        "properties": {
          "file": {
            "type": "string",
            "contentMediaType": "application/octet-stream",
            "title": "File"
          }
        },
        "type": "object",
        "required": [
          "file"
        ],
        "title": "Body_extract_pdf_extract_pdf_post"
      },
      "CheckRequest": {
        "properties": {
          "text": {
            "type": "string",
            "minLength": 1,
            "title": "Text"
          },
          "top_k": {
            "type": "integer",
            "maximum": 20.0,
            "minimum": 1.0,
            "title": "Top K",
            "nullable": true
          },
          "threshold": {
            "type": "number",
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Threshold",
            "nullable": true
          }
        },
        "type": "object",
        "required": [
          "text"
        ],
        "title": "CheckRequest"
      },
      "CheckResponse": {
        "properties": {
          "is_plagiarism": {
            "type": "boolean",
            "title": "Is Plagiarism"
          },
          "overall_score": {
            "type": "number",
            "title": "Overall Score"
          },
          "threshold": {
            "type": "number",
            "title": "Threshold"
          },
          "matches": {
            "items": {
              "$ref": "#/components/schemas/MatchResult"
            },
            "type": "array",
            "title": "Matches"
          }
        },
        "type": "object",
        "required": [
          "is_plagiarism",
          "overall_score",
          "threshold",
          "matches"
        ],
        "title": "CheckResponse"
      },
      "ErrorResponse": {
        "properties": {
          "error": {
            "type": "string",
            "title": "Error"
          },
          "message": {
            "type": "string",
            "title": "Message"
          },
          "details": {
            "items": {
              "additionalProperties": true,
              "type": "object"
            },
            "type": "array",
            "title": "Details",
            "nullable": true
          }
        },
        "type": "object",
        "required": [
          "error",
          "message"
        ],
        "title": "ErrorResponse"
      },
      "HealthResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status"
          }
        },
        "type": "object",
        "required": [
          "status"
        ],
        "title": "HealthResponse"
      },
      "IngestRequest": {
        "properties": {
          "text": {
            "type": "string",
            "minLength": 1,
            "title": "Text"
          },
          "document_id": {
            "type": "string",
            "title": "Document Id",
            "nullable": true
          },
          "source": {
            "type": "string",
            "title": "Source",
            "nullable": true
          },
          "metadata": {
            "additionalProperties": {
              "type": "string"
            },
            "type": "object",
            "title": "Metadata"
          }
        },
        "type": "object",
        "required": [
          "text"
        ],
        "title": "IngestRequest"
      },
      "IngestResponse": {
        "properties": {
          "document_id": {
            "type": "string",
            "title": "Document Id"
          },
          "chunk_count": {
            "type": "integer",
            "title": "Chunk Count"
          },
          "collection": {
            "type": "string",
            "title": "Collection"
          }
        },
        "type": "object",
        "required": [
          "document_id",
          "chunk_count",
          "collection"
        ],
        "title": "IngestResponse"
      },
      "MatchResult": {
        "properties": {
          "document_id": {
            "type": "string",
            "title": "Document Id"
          },
          "source": {
            "type": "string",
            "title": "Source",
            "nullable": true
          },
          "chunk_id": {
            "type": "string",
            "title": "Chunk Id"
          },
          "matched_text": {
            "type": "string",
            "title": "Matched Text"
          },
          "semantic_score": {
            "type": "number",
            "title": "Semantic Score"
          },
          "exact_score": {
            "type": "number",
            "title": "Exact Score"
          },
          "final_score": {
            "type": "number",
            "title": "Final Score"
          }
        },
        "type": "object",
        "required": [
          "document_id",
          "chunk_id",
          "matched_text",
          "semantic_score",
          "exact_score",
          "final_score"
        ],
        "title": "MatchResult"
      },
      "PdfExtractResponse": {
        "properties": {
          "filename": {
            "type": "string",
            "title": "Filename"
          },
          "page_count": {
            "type": "integer",
            "title": "Page Count"
          },
          "character_count": {
            "type": "integer",
            "title": "Character Count"
          },
          "text": {
            "type": "string",
            "title": "Text"
          }
        },
        "type": "object",
        "required": [
          "filename",
          "page_count",
          "character_count",
          "text"
        ],
        "title": "PdfExtractResponse"
      }
    }
  }
}