PORT=8080
LUMINA_ENGINE_BASE_URL=http://localhost:8000
LUMINA_ENGINE_TIMEOUT_SECONDS=120
# Optional: protect /v1/* routes. Clients must send X-API-Key.
LUMINA_API_KEY=
