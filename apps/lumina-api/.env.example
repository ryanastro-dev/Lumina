LUMINA_DB_MAX_OPEN_CONNS=25
LUMINA_DB_MAX_IDLE_CONNS=10
LUMINA_DB_CONN_MAX_LIFETIME_MINUTES=5

LUMINA_JOB_RETENTION_HOURS=168
LUMINA_JOB_CLEANUP_INTERVAL_MINUTES=60

