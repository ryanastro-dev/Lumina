{
  "openapi": "3.0.3",
  "info": {
    "title": "Lumina API Gateway",
    "version": "1.0.0",
    "description": "Public gateway contract for web and external clients."
  },
  "servers": [
    {
      "url": "http://127.0.0.1:8080"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "summary": "Gateway health check",
        "operationId": "gatewayHealth",
        "responses": {
          "200": {
            "description": "Gateway is available.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthPayload"
                }
              }
            }
          }
        }
      }
    },
    "/health/engine": {
      "get": {
        "summary": "Upstream engine health",
        "operationId": "gatewayEngineHealth",
        "responses": {
          "200": {
            "description": "Gateway can reach lumina-engine.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthPayload"
                }
              }
            }
          },
          "503": {
            "description": "Gateway cannot reach lumina-engine.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthPayload"
                }
              }
            }
          }
        }
      }
    },
    "/health/cleanup": {
      "get": {
        "summary": "Background cleanup status",
        "operationId": "gatewayCleanupHealth",
        "responses": {
          "200": {
            "description": "Cleanup status is healthy or disabled.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CleanupHealthResponse"
                }
              }
            }
          },
          "503": {
            "description": "Cleanup loop is enabled but degraded.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CleanupHealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/plagiarism/ingest": {
      "post": {
        "summary": "Ingest text into vector storage through gateway",
        "operationId": "gatewayIngest",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/IngestRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Document ingested.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IngestResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid JSON or invalid input.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing/invalid API key when gateway key mode is enabled.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation failed upstream.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "Upstream unavailable.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/plagiarism/check": {
      "post": {
        "summary": "Synchronous plagiarism check",
        "operationId": "gatewayCheck",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CheckRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Check completed.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CheckResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid JSON or invalid input.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing/invalid API key when gateway key mode is enabled.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation failed upstream.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "Upstream unavailable.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/plagiarism/check-jobs": {
      "post": {
        "summary": "Submit asynchronous plagiarism check job",
        "operationId": "submitCheckJob",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CheckRequest"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Job accepted.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CheckJobAcceptedResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid JSON or invalid request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing/invalid API key when gateway key mode is enabled.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "Job feature unavailable or upstream unavailable.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/plagiarism/check-jobs/{job_id}": {
      "get": {
        "summary": "Get async check job status",
        "operationId": "getCheckJob",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Job status.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CheckJobStatusResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing/invalid API key when gateway key mode is enabled.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Job not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "Job feature unavailable.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/plagiarism/check-jobs/{job_id}/cancel": {
      "post": {
        "summary": "Cancel async check job",
        "operationId": "cancelCheckJob",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "202": {
            "description": "Cancel accepted.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CheckJobAcceptedResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing/invalid API key when gateway key mode is enabled.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Job not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Job cannot be canceled in current state.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "Job feature unavailable.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/pdf/extract": {
      "post": {
        "summary": "Extract plain text from uploaded PDF",
        "operationId": "gatewayExtractPdf",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "file"
                ],
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Text extracted.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PdfExtractResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid multipart/PDF payload.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing/invalid API key when gateway key mode is enabled.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "413": {
            "description": "File too large.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation failed upstream.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "required": [
          "error",
          "message"
        ],
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "details": {
            "type": "array",
            "nullable": true,
            "items": {
              "type": "object",
              "additionalProperties": true
            }
          }
        }
      },
      "HealthPayload": {
        "type": "object",
        "required": [
          "status",
          "service"
        ],
        "properties": {
          "status": {
            "type": "string"
          },
          "service": {
            "type": "string"
          },
          "engine_status": {
            "type": "string"
          },
          "error": {
            "type": "string"
          }
        }
      },
      "CleanupSnapshot": {
        "type": "object",
        "required": [
          "enabled",
          "retention_seconds",
          "interval_seconds",
          "last_deleted_count",
          "total_runs",
          "total_failures",
          "total_deleted"
        ],
        "properties": {
          "enabled": {
            "type": "boolean"
          },
          "reason": {
            "type": "string"
          },
          "retention_seconds": {
            "type": "integer",
            "format": "int64"
          },
          "interval_seconds": {
            "type": "integer",
            "format": "int64"
          },
          "last_trigger": {
            "type": "string"
          },
          "last_run_at": {
            "type": "string",
            "format": "date-time"
          },
          "last_cutoff_at": {
            "type": "string",
            "format": "date-time"
          },
          "last_success_at": {
            "type": "string",
            "format": "date-time"
          },
          "last_deleted_count": {
            "type": "integer",
            "format": "int64"
          },
          "last_error": {
            "type": "string"
          },
          "total_runs": {
            "type": "integer",
            "format": "int64"
          },
          "total_failures": {
            "type": "integer",
            "format": "int64"
          },
          "total_deleted": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "CleanupHealthResponse": {
        "type": "object",
        "required": [
          "status",
          "service",
          "cleanup"
        ],
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "ok",
              "degraded",
              "disabled"
            ]
          },
          "service": {
            "type": "string"
          },
          "cleanup": {
            "$ref": "#/components/schemas/CleanupSnapshot"
          }
        }
      },
      "IngestRequest": {
        "type": "object",
        "required": [
          "text"
        ],
        "properties": {
          "text": {
            "type": "string",
            "minLength": 1
          },
          "document_id": {
            "type": "string",
            "nullable": true
          },
          "source": {
            "type": "string",
            "nullable": true
          },
          "metadata": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      },
      "IngestResponse": {
        "type": "object",
        "required": [
          "document_id",
          "chunk_count",
          "collection"
        ],
        "properties": {
          "document_id": {
            "type": "string"
          },
          "chunk_count": {
            "type": "integer"
          },
          "collection": {
            "type": "string"
          }
        }
      },
      "CheckRequest": {
        "type": "object",
        "required": [
          "text"
        ],
        "properties": {
          "text": {
            "type": "string",
            "minLength": 1
          },
          "top_k": {
            "type": "integer",
            "minimum": 1,
            "maximum": 20,
            "nullable": true
          },
          "threshold": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "nullable": true
          }
        }
      },
      "MatchResult": {
        "type": "object",
        "required": [
          "document_id",
          "chunk_id",
          "matched_text",
          "semantic_score",
          "exact_score",
          "final_score"
        ],
        "properties": {
          "document_id": {
            "type": "string"
          },
          "source": {
            "type": "string",
            "nullable": true
          },
          "chunk_id": {
            "type": "string"
          },
          "matched_text": {
            "type": "string"
          },
          "semantic_score": {
            "type": "number"
          },
          "exact_score": {
            "type": "number"
          },
          "final_score": {
            "type": "number"
          }
        }
      },
      "CheckResponse": {
        "type": "object",
        "required": [
          "is_plagiarism",
          "overall_score",
          "threshold",
          "matches"
        ],
        "properties": {
          "is_plagiarism": {
            "type": "boolean"
          },
          "overall_score": {
            "type": "number"
          },
          "threshold": {
            "type": "number"
          },
          "matches": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MatchResult"
            }
          }
        }
      },
      "CheckJobAcceptedResponse": {
        "type": "object",
        "required": [
          "job_id",
          "status"
        ],
        "properties": {
          "job_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "CheckJobStatusResponse": {
        "type": "object",
        "required": [
          "job_id",
          "status",
          "created_at"
        ],
        "properties": {
          "job_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "started_at": {
            "type": "string",
            "format": "date-time"
          },
          "completed_at": {
            "type": "string",
            "format": "date-time"
          },
          "error": {
            "type": "string"
          },
          "result": {
            "$ref": "#/components/schemas/CheckResponse"
          }
        }
      },
      "PdfExtractResponse": {
        "type": "object",
        "required": [
          "filename",
          "page_count",
          "character_count",
          "text"
        ],
        "properties": {
          "filename": {
            "type": "string"
          },
          "page_count": {
            "type": "integer"
          },
          "character_count": {
            "type": "integer"
          },
          "text": {
            "type": "string"
          }
        }
      }
    }
  }
}
