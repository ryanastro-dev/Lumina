# Shared local environment (root-level)
GATEWAY_PORT=8080
WEB_PORT=3000
LUMINA_ENGINE_PORT=8000

LUMINA_ENGINE_BASE_URL=http://localhost:8000
LUMINA_ENGINE_TIMEOUT_SECONDS=120
LUMINA_JOB_RETENTION_HOURS=168
LUMINA_JOB_CLEANUP_INTERVAL_MINUTES=60
# Optional: protect lumina-api /v1/* routes.
LUMINA_API_KEY=

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=lumina
POSTGRES_USER=lumina
POSTGRES_PASSWORD=lumina_dev

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=lumina_documents
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L12-v2
CHUNK_SIZE=240
CHUNK_OVERLAP=60
SIMILARITY_THRESHOLD=0.80
TOP_K=5

